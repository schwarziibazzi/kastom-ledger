generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  sevispassUid       String   @unique
  name               String
  dateOfBirth        DateTime
  province           String
  phone              String?
  occupation         String?
  profilePhoto       String?
  role               String   @default("OWNER")
  verificationStatus String   @default("verified")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Sevis Ecosystem Fields
  sevisDid             String? // Decentralized Identifier (DID)
  sevisPassTier        String    @default("Tier-1")
  sevisWalletPhone     String? // Phone number bound to wallet
  sevisWalletInstalled Boolean   @default(false)
  sevisWalletLastSync  DateTime?

  // Relations
  legacyProfile              LegacyProfile?
  legacyItems                LegacyItem[]
  successorNominations       Successor[]                 @relation("SuccessorNominations")
  successorOf                Successor[]                 @relation("SuccessorOf")
  witnessRecords             Witness[]                   @relation("WitnessRecords")
  ledgerEntries              LedgerEntry[]
  successionEvents           SuccessionEvent[]
  estates                    Estate[]                    @relation("EstateOwner")
  executorOf                 Estate[]                    @relation("EstateExecutor")
  beneficiaryOf              Beneficiary[]
  estateWitness              EstateWitness[]
  notifications              Notification[]
  activityLogs               ActivityLog[]
  institutionRequests        InstitutionRequest[]
  folders                    Folder[]
  documents                  Document[]
  audioFiles                 AudioFile[]
  sevisDexRequests           SevisDexRequest[]
  deathVerifications         DeathVerification[]         @relation("DeathRequester")
  deathVerificationsVerified DeathVerification[]         @relation("DeathVerifier")
  successionTransfers        SuccessionTransfer[]        @relation("TransferFrom")
  successionTransfersTo      SuccessionTransfer[]        @relation("TransferTo")
  walletCredentials          WalletCredential[]
  peerDataRequests           PeerDataRequest[]           @relation("Requester")
  peerDataResponses          PeerDataRequest[]           @relation("Responder")
  userConnections            UserIntegrationConnection[]

  @@map("users")
}

model WalletCredential {
  id             String    @id @default(uuid())
  userId         String
  credentialType String // 'sevispass', 'drivers_license', 'nasfund', 'academic'
  credentialData Json // The actual credential data
  issuer         String // Who issued this credential
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime?
  verified       Boolean   @default(false)
  verifiedAt     DateTime?
  credentialHash String // SHA-256 hash for tamper-proofing

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("wallet_credentials")
}

model PeerDataRequest {
  id                String    @id @default(uuid())
  requesterId       String // User requesting data
  responderId       String // User providing data (the wallet owner)
  requestType       String // 'identity_verification', 'estate_verification', 'asset_verification'
  requestData       Json // What is being requested
  responseData      Json? // Data provided by wallet
  status            String    @default("pending") // pending, approved, rejected, completed
  sevisDexReference String?
  encryptionKey     String? // P2P encryption key
  requestedAt       DateTime  @default(now())
  respondedAt       DateTime?
  expiresAt         DateTime?

  // Relations
  requester User @relation("Requester", fields: [requesterId], references: [id])
  responder User @relation("Responder", fields: [responderId], references: [id])

  @@map("peer_data_requests")
}

model LegacyProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  title         String
  description   String?
  culturalNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user       User         @relation(fields: [userId], references: [id])
  items      LegacyItem[]
  successors Successor[]
  witnesses  Witness[]

  @@map("legacy_profiles")
}

model LegacyItem {
  id          String   @id @default(uuid())
  ownerUid    String
  category    String
  title       String
  description String?
  fileUrl     String?
  visibility  String   @default("private")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  profile   LegacyProfile @relation(fields: [profileId], references: [id])
  profileId String
  owner     User          @relation(fields: [ownerUid], references: [sevispassUid])

  @@map("legacy_items")
}

model Successor {
  id             String   @id @default(uuid())
  legacyOwnerUid String
  successorUid   String
  relationship   String
  accessLevel    String   @default("viewer")
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  legacyProfile   LegacyProfile    @relation(fields: [legacyProfileId], references: [id])
  legacyProfileId String
  owner           User             @relation("SuccessorNominations", fields: [legacyOwnerUid], references: [sevispassUid])
  successor       User             @relation("SuccessorOf", fields: [successorUid], references: [sevispassUid])
  witness         Witness?
  successionEvent SuccessionEvent?

  @@map("successors")
}

model Witness {
  id               String   @id @default(uuid())
  witnessUid       String
  actionVerified   String
  timestamp        DateTime @default(now())
  digitalSignature String?
  comments         String?

  // Relations
  successor       Successor     @relation(fields: [successorId], references: [id])
  successorId     String        @unique
  witness         User          @relation("WitnessRecords", fields: [witnessUid], references: [sevispassUid])
  legacyProfile   LegacyProfile @relation(fields: [legacyProfileId], references: [id])
  legacyProfileId String

  @@map("witnesses")
}

model SuccessionEvent {
  id              String    @id @default(uuid())
  successorId     String    @unique
  ownerUid        String
  status          String    @default("pending")
  accessGrantedAt DateTime?
  deathVerified   Boolean   @default(false)
  deathVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  successor Successor @relation(fields: [successorId], references: [id])
  owner     User      @relation(fields: [ownerUid], references: [sevispassUid])

  @@map("succession_events")
}

model LedgerEntry {
  id           String   @id @default(uuid())
  actionType   String
  timestamp    DateTime @default(now())
  previousHash String?
  currentHash  String
  metadata     Json?
  actorUid     String

  // Relations
  user User @relation(fields: [actorUid], references: [sevispassUid])

  @@map("ledger_entries")
}

model Estate {
  id                      String    @id @default(uuid())
  ownerId                 String
  executorId              String?
  title                   String
  description             String?
  status                  String    @default("DRAFT")
  completionPercentage    Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  finalisedAt             DateTime?
  deathVerifiedAt         DateTime?
  deathCertificate        String?
  deathVerifiedBy         String?
  deathVerificationHash   String?
  successionCompleted     Boolean   @default(false)
  successionCompletedAt   DateTime?
  publicCuratorReview     Boolean   @default(false)
  publicCuratorApproved   Boolean   @default(false)
  publicCuratorReviewedAt DateTime?

  // Relations
  owner               User                 @relation("EstateOwner", fields: [ownerId], references: [id])
  executor            User?                @relation("EstateExecutor", fields: [executorId], references: [id])
  assets              Asset[]
  beneficiaries       Beneficiary[]
  witnesses           EstateWitness[]
  digitalWill         DigitalWill?
  institutionRequests InstitutionRequest[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  documents           Document[]
  sevisDexRequests    SevisDexRequest[]
  deathVerifications  DeathVerification[]
  successionTransfers SuccessionTransfer[]

  @@map("estates")
}

model Asset {
  id             String   @id @default(uuid())
  estateId       String
  type           String
  title          String
  description    String?
  estimatedValue Float?
  location       String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Sevis DEx Integration Fields
  sevisDexReference    String?
  sevisDexVerified     Boolean   @default(false)
  sevisDexVerifiedAt   DateTime?
  sevisDexData         Json?
  sevisDexStatus       String    @default("pending")
  department           String?
  departmentReference  String?
  titleNumber          String?
  registrationNumber   String?
  businessNumber       String?
  accountNumber        String?
  superannuationNumber String?

  // Government Integration Fields
  registryAuthority    String? // 'Department of Lands', 'MVIL', 'IPA', 'BSP', 'Kina Bank'
  registryReference    String? // Reference number from registry
  verificationStatus   String    @default("self_declared") // self_declared, government_verified
  importedVia          String? // 'sevisdex', 'manual'
  lastVerificationDate DateTime?

  // Relations
  estate           Estate            @relation(fields: [estateId], references: [id])
  documents        Document[]
  beneficiaryId    String?
  beneficiary      Beneficiary?      @relation(fields: [beneficiaryId], references: [id])
  sevisDexRequests SevisDexRequest[]

  @@map("assets")
}

model Beneficiary {
  id                    String    @id @default(uuid())
  estateId              String
  userId                String?
  name                  String
  email                 String?
  relationship          String
  sharePercentage       Float?
  status                String    @default("pending")
  invitationToken       String?
  invitedAt             DateTime  @default(now())
  acceptedAt            DateTime?
  claimedAt             DateTime?
  successionActivated   Boolean   @default(false)
  successionActivatedAt DateTime?

  // Relations
  estate Estate  @relation(fields: [estateId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])
  assets Asset[]

  @@map("beneficiaries")
}

model EstateWitness {
  id         String    @id @default(uuid())
  estateId   String
  witnessId  String
  status     String    @default("pending")
  comments   String?
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  estate  Estate @relation(fields: [estateId], references: [id])
  witness User   @relation(fields: [witnessId], references: [id])

  @@map("estate_witnesses")
}

model DigitalWill {
  id                      String    @id @default(uuid())
  estateId                String    @unique
  introduction            String?
  introductionAudio       String?
  introductionAudioDocId  String? // Just store the ID, no relation
  executorNotes           String?
  executorAudio           String?
  executorAudioDocId      String? // Just store the ID, no relation
  personalMessages        String?
  messagesAudio           String?
  messagesAudioDocId      String? // Just store the ID, no relation
  status                  String    @default("draft")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  submittedAt             DateTime?
  publicCuratorVerified   Boolean   @default(false)
  publicCuratorVerifiedAt DateTime?

  // Relations
  estate    Estate        @relation(fields: [estateId], references: [id])
  witnesses WillWitness[]
  // REMOVED: introductionAudioDoc, executorAudioDoc, messagesAudioDoc relations

  @@map("digital_wills")
}

model WillWitness {
  id           String    @id @default(uuid())
  willId       String
  name         String
  email        String?
  relationship String?
  signature    String?
  verifiedAt   DateTime?
  status       String    @default("pending")

  // Relations
  will DigitalWill @relation(fields: [willId], references: [id])

  @@map("will_witnesses")
}

model SevisDexRequest {
  id                  String    @id @default(uuid())
  assetId             String
  estateId            String
  userId              String
  requestType         String
  referenceNumber     String    @unique
  requestData         Json
  responseData        Json?
  status              String    @default("pending")
  sevisDexReference   String?
  department          String
  departmentReference String?
  verifiedBy          String?
  verifiedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  completedAt         DateTime?

  // Relations
  asset  Asset  @relation(fields: [assetId], references: [id])
  estate Estate @relation(fields: [estateId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("sevis_dex_requests")
}

model DeathVerification {
  id                     String    @id @default(uuid())
  estateId               String
  requesterId            String
  verifiedById           String?
  deathCertificate       String
  certificateHash        String
  status                 String    @default("pending")
  sevisDexReference      String?
  civilRegistryReference String?
  publicCuratorReference String?
  comments               String?
  requestedAt            DateTime  @default(now())
  verifiedAt             DateTime?
  expiresAt              DateTime?
  deathRegisteredAt      DateTime?

  // Relations
  estate     Estate @relation(fields: [estateId], references: [id])
  requester  User   @relation("DeathRequester", fields: [requesterId], references: [id])
  verifiedBy User?  @relation("DeathVerifier", fields: [verifiedById], references: [id])

  @@map("death_verifications")
}

model SuccessionTransfer {
  id                          String    @id @default(uuid())
  estateId                    String
  fromUserId                  String
  toUserId                    String
  assetIds                    Json
  status                      String    @default("pending")
  transferredAt               DateTime?
  sevisDexReference           String?
  ledgerHash                  String?
  departmentTransferReference String?
  department                  String
  transferType                String

  // Relations
  estate   Estate @relation(fields: [estateId], references: [id])
  fromUser User   @relation("TransferFrom", fields: [fromUserId], references: [id])
  toUser   User   @relation("TransferTo", fields: [toUserId], references: [id])

  @@map("succession_transfers")
}

model GovernmentIntegration {
  id               String    @id @default(uuid())
  name             String
  serviceType      String // 'sevispass', 'seviswallet', 'sevisdex', 'civil_registry', 'dlpp', 'ipa', 'mvil', 'banking'
  connectionStatus String    @default("disconnected") // connected, disconnected, error
  healthStatus     String    @default("unknown") // healthy, degraded, error, unknown
  apiVersion       String?
  environment      String    @default("sandbox") // sandbox, production
  lastSync         DateTime?
  lastSyncStatus   String? // success, failed, partial
  configuration    Json? // API endpoint, client ID, etc.
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  syncLogs        IntegrationSyncLog[]
  userConnections UserIntegrationConnection[]

  @@map("government_integrations")
}

model IntegrationSyncLog {
  id            String   @id @default(uuid())
  integrationId String
  status        String // success, failed, warning
  message       String?
  details       Json?
  createdAt     DateTime @default(now())

  // Relations
  integration GovernmentIntegration @relation(fields: [integrationId], references: [id])

  @@map("integration_sync_logs")
}

model UserIntegrationConnection {
  id             String    @id @default(uuid())
  userId         String
  integrationId  String
  connected      Boolean   @default(false)
  connectedAt    DateTime?
  estateId       String?
  assetsImported Int       @default(0)
  lastImportAt   DateTime?
  connectionData Json? // Any user-specific connection data
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  user        User                  @relation(fields: [userId], references: [id])
  integration GovernmentIntegration @relation(fields: [integrationId], references: [id])

  @@map("user_integration_connections")
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  ownerId     String
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner      User        @relation(fields: [ownerId], references: [id])
  parent     Folder?     @relation("FolderParent", fields: [parentId], references: [id])
  children   Folder[]    @relation("FolderParent")
  documents  Document[]
  audioFiles AudioFile[]

  @@map("folders")
}

model AudioFile {
  id          String   @id @default(uuid())
  folderId    String?
  title       String
  description String?
  fileUrl     String
  fileSize    Int
  duration    Int?
  uploadedBy  String
  category    String   @default("will_audio")
  relatedTo   String?
  relatedId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  folder Folder? @relation(fields: [folderId], references: [id])
  user   User    @relation(fields: [uploadedBy], references: [id])

  @@map("audio_files")
}

model Document {
  id               String    @id @default(uuid())
  folderId         String?
  title            String
  description      String?
  fileUrl          String
  fileType         String
  fileSize         Int
  mimeType         String
  visibility       String    @default("private")
  uploadedBy       String
  category         String    @default("general")
  estateId         String?
  assetId          String?
  tags             String[]
  checksum         String?
  ledgerHash       String?
  digitalSignature String?
  signatureDate    DateTime?
  verifiedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  folder Folder? @relation(fields: [folderId], references: [id])
  user   User    @relation(fields: [uploadedBy], references: [id])
  estate Estate? @relation(fields: [estateId], references: [id])
  asset  Asset?  @relation(fields: [assetId], references: [id])

  @@map("documents")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  estateId  String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  // Relations
  user   User    @relation(fields: [userId], references: [id])
  estate Estate? @relation(fields: [estateId], references: [id])

  @@map("notifications")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  estateId  String?
  action    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Relations
  user   User    @relation(fields: [userId], references: [id])
  estate Estate? @relation(fields: [estateId], references: [id])

  @@map("activity_logs")
}

model InstitutionRequest {
  id              String    @id @default(uuid())
  estateId        String
  userId          String
  type            String
  institutionName String
  referenceNumber String?
  status          String    @default("pending")
  documents       Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  submittedAt     DateTime?
  completedAt     DateTime?

  // Relations
  estate Estate @relation(fields: [estateId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("institution_requests")
}
